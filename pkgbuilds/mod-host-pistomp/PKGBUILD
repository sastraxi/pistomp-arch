# Maintainer: pistomp
pkgname=mod-host-pistomp
pkgver=0.10.6
pkgrel=2
pkgdesc="LV2 host for MOD devices (pi-stomp build)"
arch=('aarch64')
url="https://github.com/mod-audio/mod-host"
license=('GPL2')
depends=('jack2' 'lilv' 'fftw' 'liblo' 'readline')
makedepends=('git' 'hylia')
provides=('mod-host' 'lv2-host')
conflicts=('mod-host')

_repo="https://github.com/sastraxi/mod-host.git"
_branch="fix/effect-drain-midi"

source=("mod-host::git+${_repo}#branch=${_branch}")
sha256sums=('SKIP')

build() {
    cd mod-host
    make
}

package() {
    cd mod-host
    install -Dm755 mod-host "${pkgdir}/usr/bin/mod-host"
}
