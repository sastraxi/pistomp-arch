[Unit]
Description=pi-Stomp Recovery Service
After=mod-ala-pi-stomp.service
Conflicts=mod-ala-pi-stomp.service

[Service]
Type=simple
User=pistomp
Group=pistomp
Environment=JACK_PROMISCUOUS_SERVER=jack
WorkingDirectory=/home/pistomp
ExecStart=/opt/pistomp/venvs/pistomp-recovery/bin/python -m pistomp_recovery
Restart=no
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target